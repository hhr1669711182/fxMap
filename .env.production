
# Vite env (custom file). Variables with VITE_ prefix are exposed to the client.
VITE_APP_ENV=production

VITE_WS_URL=ws://localhost:8080/dispatch

VITE_ROUTE_API_URL=

VITE_GEOSERVER_URL=http://192.168.172.103:8090/geoserver/

VITE_PERSIST_SECRET_KEY=

VITE_ENABLE_DYNAMIC_ROUTES=false

VITE_USE_WS=true
VITE_USE_POSTMESSAGE=true

# Icon system
VITE_USE_ONLINE_ICON=false

# Mock
VITE_USE_MOCK=false

# Panels (iframe)
VITE_PANEL_25D_URL=
VITE_PANEL_3D_URL=
